class LessBalanceException extends Exception {
    private double amount;

    public LessBalanceException(double amount) {
        this.amount = amount;
    }

    public String toString() {
        return ("Withdraw amount (Rs " + amount + ") is not valid. Insufficient balance.");
    }
}

class BankAccount {
    private double balance;

    public BankAccount(double initialBalance) {
        if (initialBalance < 1000) {
            System.out.println("Minimum balance should be Rs 1000. Setting balance to Rs 1000.");
            balance = 1000;
        } else {
            balance = initialBalance;
        }
    }

    public void deposit(double amount) {
        balance += amount;
        System.out.println("Deposited Rs " + amount);
        System.out.println("Current Balance: Rs " + balance);
    }

    public void withdraw(double amount) throws LessBalanceException {
        if (balance - amount < 1000) {
            throw new LessBalanceException(amount);
        } else {
            balance -= amount;
            System.out.println("Withdrawn: Rs " + amount);
            System.out.println("Current Balance: Rs " + balance);
        }
    }

    public double getBalance() {
        return balance;
    }
}

public class BankingSystem {
    public static void main(String[] args) {

        try {
            BankAccount acc = new BankAccount(1500);
            acc.deposit(500);
            acc.withdraw(400);
            acc.withdraw(800);

        } catch (LessBalanceException e) {
            System.out.println(e);
        }

        try {
            int a = 10;
            int b = 0;
            int result = a / b;
            System.out.println("Result = " + result);

        } catch (ArithmeticException e) {
            System.out.println("Arithmetic Exception caught: Division by zero is not allowed.");
        }
    }
}
